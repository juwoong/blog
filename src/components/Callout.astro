---
interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<aside class="callout" role="note">
  {title && <div class="callout-title">{title}</div>}
  <div class="callout-body">
    <slot />
  </div>
</aside>

<style>
  .callout {
    margin: 0 0 2em;
    padding: 0 0 0 1rem;
    border-left: 3px solid #64748b;
    color: rgb(var(--gray-dark));
  }

  .callout-title {
    margin-bottom: 0.35rem;
    color: #475569;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.4;
  }

  .callout-body {
    line-height: 1.8;
  }

  .callout-body :global(p:first-child) {
    margin-top: 0;
  }

  .callout-body :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
