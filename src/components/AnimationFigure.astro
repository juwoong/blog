---
interface Props {
  caption?: string;
}

const { caption } = Astro.props;
---

<figure class="animation-figure">
  <div class="animation-figure-body">
    <slot />
  </div>
  {caption && <figcaption set:html={caption} />}
</figure>

<style>
  .animation-figure {
    margin: 0.75em 0 1.5em;
    text-align: center;
  }

  .animation-figure-body {
    width: 100%;
  }

  .animation-figure figcaption {
    margin-top: 0.5em;
    font-size: 0.9em;
    color: rgb(var(--gray));
  }
</style>
