---
interface Props {
  height?: string;
}

const { height = "250px" } = Astro.props;
---

<div class="calibration-detour-container" style={`height: ${height}`}>
  <canvas class="calibration-detour-canvas"></canvas>
</div>

<style>
  .calibration-detour-container {
    width: 100%;
  }

  .calibration-detour-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>

<script>
  type Point = { x: number; y: number };

  class CalibrationDetourAnimation {
    private canvas: HTMLCanvasElement;
    private ctx: CanvasRenderingContext2D;
    private container: HTMLElement;
    private lastTime = 0;
    private progress = 0;
    private duration = 5200;
    private pauseTime = 1200;
    private pauseStartTime = 0;
    private isPaused = false;

    constructor(canvas: HTMLCanvasElement) {
      this.canvas = canvas;
      this.ctx = canvas.getContext("2d")!;
      this.container = canvas.parentElement!;
      this.init();
    }

    private init() {
      this.resizeCanvas();
      window.addEventListener("resize", () => this.resizeCanvas());
      this.loop(0);
    }

    private resizeCanvas() {
      const dpr = window.devicePixelRatio || 1;
      const rect = this.container.getBoundingClientRect();

      this.canvas.width = rect.width * dpr;
      this.canvas.height = rect.height * dpr;
      this.canvas.style.width = `${rect.width}px`;
      this.canvas.style.height = `${rect.height}px`;
      this.ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      this.draw();
    }

    private lerp(start: number, end: number, t: number) {
      return start + (end - start) * t;
    }

    private clamp(value: number, min: number, max: number) {
      return Math.min(max, Math.max(min, value));
    }

    private distance(a: Point, b: Point) {
      return Math.hypot(b.x - a.x, b.y - a.y);
    }

    private centroid(points: Point[]) {
      const sum = points.reduce(
        (acc, point) => ({
          x: acc.x + point.x,
          y: acc.y + point.y,
        }),
        { x: 0, y: 0 }
      );

      return {
        x: sum.x / points.length,
        y: sum.y / points.length,
      };
    }

    private scalePolygon(points: Point[], scaleX: number, scaleY: number) {
      const center = this.centroid(points);
      return points.map((point) => ({
        x: center.x + (point.x - center.x) * scaleX,
        y: center.y + (point.y - center.y) * scaleY,
      }));
    }

    private drawClosedPolygon(
      points: Point[],
      fillStyle?: string | CanvasGradient,
      strokeStyle?: string,
      lineWidth = 1
    ) {
      this.ctx.beginPath();
      this.ctx.moveTo(points[0].x, points[0].y);
      for (let i = 1; i < points.length; i += 1) {
        this.ctx.lineTo(points[i].x, points[i].y);
      }
      this.ctx.closePath();

      if (fillStyle) {
        this.ctx.fillStyle = fillStyle;
        this.ctx.fill();
      }

      if (strokeStyle) {
        this.ctx.strokeStyle = strokeStyle;
        this.ctx.lineWidth = lineWidth;
        this.ctx.stroke();
      }
    }

    private drawPolyline(points: Point[], strokeStyle: string | CanvasGradient, lineWidth: number) {
      this.ctx.beginPath();
      this.ctx.moveTo(points[0].x, points[0].y);
      for (let i = 1; i < points.length; i += 1) {
        this.ctx.lineTo(points[i].x, points[i].y);
      }
      this.ctx.strokeStyle = strokeStyle;
      this.ctx.lineWidth = lineWidth;
      this.ctx.lineCap = "round";
      this.ctx.lineJoin = "round";
      this.ctx.stroke();
    }

    private drawDottedPolyline(points: Point[], strokeStyle: string, lineWidth: number) {
      this.ctx.save();
      this.ctx.setLineDash([6, 8]);
      this.drawPolyline(points, strokeStyle, lineWidth);
      this.ctx.restore();
    }

    private drawPartialPolyline(
      points: Point[],
      progress: number,
      strokeStyle: string | CanvasGradient,
      lineWidth: number
    ) {
      const totalLength = points.slice(1).reduce((sum, point, index) => {
        return sum + this.distance(points[index], point);
      }, 0);
      const targetLength = totalLength * progress;

      this.ctx.beginPath();
      this.ctx.moveTo(points[0].x, points[0].y);

      let traversed = 0;
      for (let i = 1; i < points.length; i += 1) {
        const previous = points[i - 1];
        const current = points[i];
        const segment = this.distance(previous, current);

        if (traversed + segment <= targetLength) {
          this.ctx.lineTo(current.x, current.y);
          traversed += segment;
          continue;
        }

        const remaining = targetLength - traversed;
        const ratio = segment === 0 ? 0 : remaining / segment;
        const x = this.lerp(previous.x, current.x, ratio);
        const y = this.lerp(previous.y, current.y, ratio);
        this.ctx.lineTo(x, y);
        break;
      }

      this.ctx.strokeStyle = strokeStyle;
      this.ctx.lineWidth = lineWidth;
      this.ctx.lineCap = "round";
      this.ctx.lineJoin = "round";
      this.ctx.stroke();
    }

    private pointOnPolyline(points: Point[], progress: number) {
      const totalLength = points.slice(1).reduce((sum, point, index) => {
        return sum + this.distance(points[index], point);
      }, 0);
      const targetLength = totalLength * progress;

      let traversed = 0;
      for (let i = 1; i < points.length; i += 1) {
        const previous = points[i - 1];
        const current = points[i];
        const segment = this.distance(previous, current);

        if (traversed + segment >= targetLength) {
          const ratio = segment === 0 ? 0 : (targetLength - traversed) / segment;
          return {
            x: this.lerp(previous.x, current.x, ratio),
            y: this.lerp(previous.y, current.y, ratio),
          };
        }

        traversed += segment;
      }

      return points[points.length - 1];
    }

    private drawPoint(point: Point, label: string) {
      this.ctx.save();
      this.ctx.shadowColor = "rgba(100, 116, 139, 0.12)";
      this.ctx.shadowBlur = 8;
      this.ctx.beginPath();
      this.ctx.arc(point.x, point.y, 6, 0, Math.PI * 2);
      this.ctx.fillStyle = "#1e293b";
      this.ctx.fill();
      this.ctx.restore();

      this.ctx.beginPath();
      this.ctx.arc(point.x, point.y, 14, 0, Math.PI * 2);
      this.ctx.strokeStyle = "rgba(71, 85, 105, 0.15)";
      this.ctx.lineWidth = 1;
      this.ctx.stroke();

      this.ctx.fillStyle = "#475569";
      this.ctx.font = 'italic 12px "Times New Roman", serif';
      this.ctx.textAlign = "center";
      this.ctx.textBaseline = "top";
      this.ctx.fillText(label, point.x, point.y + 18);
    }

    private drawTraveler(point: Point, fill: string, stroke: string, glow: string, radius = 7) {
      this.ctx.save();
      this.ctx.shadowColor = glow;
      this.ctx.shadowBlur = 18;
      this.ctx.beginPath();
      this.ctx.arc(point.x, point.y, radius, 0, Math.PI * 2);
      this.ctx.fillStyle = fill;
      this.ctx.fill();
      this.ctx.strokeStyle = stroke;
      this.ctx.lineWidth = 2;
      this.ctx.stroke();
      this.ctx.restore();
    }

    private draw() {
      const rect = this.container.getBoundingClientRect();
      const width = rect.width;
      const height = rect.height;
      const start = { x: width * 0.24, y: height * 0.68 };
      const end = { x: width * 0.76, y: height * 0.34 };
      const ravine = [
        { x: width * 0.47, y: height * 0.21 },
        { x: width * 0.56, y: height * 0.2 },
        { x: width * 0.61, y: height * 0.28 },
        { x: width * 0.59, y: height * 0.39 },
        { x: width * 0.64, y: height * 0.52 },
        { x: width * 0.61, y: height * 0.71 },
        { x: width * 0.54, y: height * 0.83 },
        { x: width * 0.46, y: height * 0.8 },
        { x: width * 0.41, y: height * 0.69 },
        { x: width * 0.39, y: height * 0.55 },
        { x: width * 0.42, y: height * 0.37 },
      ];
      const ravineCenter = { x: width * 0.515, y: height * 0.52 };
      const directLeft = { x: width * 0.41, y: height * 0.56 };
      const directRight = { x: width * 0.61, y: height * 0.43 };
      const safePoints = [
        start,
        { x: width * 0.28, y: height * 0.58 },
        { x: width * 0.36, y: height * 0.42 },
        { x: width * 0.47, y: height * 0.16 },
        { x: width * 0.63, y: height * 0.15 },
        { x: width * 0.73, y: height * 0.21 },
        { x: width * 0.77, y: height * 0.28 },
        end,
      ];
      const straightEnd = 0.34;
      const sinkEnd = 0.5;
      const safeStart = 0.6;
      const safeEnd = 0.94;

      this.ctx.clearRect(0, 0, width, height);

      const terrainZone = this.scalePolygon(ravine, 1.55, 1.42);
      const contour1 = this.scalePolygon(ravine, 1.18, 1.16);
      const contour2 = this.scalePolygon(ravine, 1.34, 1.28);
      const contour3 = this.scalePolygon(ravine, 1.52, 1.38);

      this.drawClosedPolygon(terrainZone, "rgba(226, 232, 240, 0.16)");
      this.drawClosedPolygon(contour3, undefined, "rgba(148, 163, 184, 0.16)", 1.15);
      this.drawClosedPolygon(contour2, undefined, "rgba(148, 163, 184, 0.18)", 1.2);
      this.drawClosedPolygon(contour1, undefined, "rgba(148, 163, 184, 0.22)", 1.25);

      const ravineGradient = this.ctx.createLinearGradient(
        width * 0.42,
        height * 0.24,
        width * 0.6,
        height * 0.84
      );
      ravineGradient.addColorStop(0, "rgba(51, 65, 85, 0.92)");
      ravineGradient.addColorStop(1, "rgba(15, 23, 42, 0.98)");
      this.drawClosedPolygon(ravine, ravineGradient, "rgba(226, 232, 240, 0.12)", 1.1);
      this.drawClosedPolygon(
        this.scalePolygon(ravine, 0.78, 0.8),
        "rgba(2, 6, 23, 0.28)"
      );

      this.ctx.fillStyle = "rgba(203, 213, 225, 0.76)";
      this.ctx.font = 'italic 12px "Times New Roman", serif';
      this.ctx.textAlign = "center";
      this.ctx.textBaseline = "middle";
      this.ctx.fillText("dead end", ravineCenter.x, ravineCenter.y);

      this.drawDottedPolyline(safePoints, "rgba(100, 116, 139, 0.28)", 1.6);

      this.ctx.beginPath();
      this.ctx.moveTo(start.x, start.y);
      this.ctx.lineTo(directLeft.x, directLeft.y);
      this.ctx.moveTo(directRight.x, directRight.y);
      this.ctx.lineTo(end.x, end.y);
      this.ctx.strokeStyle = "rgba(127, 29, 29, 0.3)";
      this.ctx.lineWidth = 2;
      this.ctx.setLineDash([7, 8]);
      this.ctx.stroke();
      this.ctx.setLineDash([]);

      this.drawPoint(start, "A");
      this.drawPoint(end, "B");

      const safeGlow = this.ctx.createLinearGradient(start.x, 0, end.x, 0);
      safeGlow.addColorStop(0, "rgba(100, 116, 139, 0.55)");
      safeGlow.addColorStop(0.6, "rgba(51, 65, 85, 0.88)");
      safeGlow.addColorStop(1, "rgba(15, 23, 42, 0.76)");

      if (this.progress <= straightEnd) {
        const directProgress = this.progress / straightEnd;
        const x = this.lerp(start.x, directLeft.x, directProgress);
        const y = this.lerp(start.y, directLeft.y, directProgress);
        this.drawTraveler({ x, y }, "#ffffff", "#7f1d1d", "rgba(127, 29, 29, 0.18)");
      } else if (this.progress <= sinkEnd) {
        const sinkProgress = (this.progress - straightEnd) / (sinkEnd - straightEnd);
        const x = this.lerp(directLeft.x, ravineCenter.x, sinkProgress);
        const y = this.lerp(directLeft.y, ravineCenter.y, sinkProgress);
        const radius = this.lerp(7, 4.5, sinkProgress);

        this.ctx.beginPath();
        this.ctx.moveTo(directLeft.x, directLeft.y);
        this.ctx.lineTo(x, y);
        this.ctx.strokeStyle = "rgba(127, 29, 29, 0.34)";
        this.ctx.lineWidth = 2;
        this.ctx.setLineDash([4, 6]);
        this.ctx.stroke();
        this.ctx.setLineDash([]);

        this.drawTraveler(
          { x, y },
          "#ffffff",
          "#7f1d1d",
          "rgba(127, 29, 29, 0.16)",
          radius
        );

        this.ctx.beginPath();
        this.ctx.arc(ravineCenter.x, ravineCenter.y, 8 + sinkProgress * 8, 0, Math.PI * 2);
        this.ctx.strokeStyle = `rgba(248, 250, 252, ${0.08 + sinkProgress * 0.1})`;
        this.ctx.lineWidth = 1;
        this.ctx.stroke();
      } else if (this.progress >= safeStart) {
        const routeProgress = this.clamp((this.progress - safeStart) / (safeEnd - safeStart), 0, 1);
        this.drawPartialPolyline(safePoints, routeProgress, safeGlow, 4);
        const traveler = this.pointOnPolyline(safePoints, routeProgress);
        this.drawTraveler(traveler, "#ffffff", "#334155", "rgba(71, 85, 105, 0.18)");
      }
    }

    private loop = (timestamp: number) => {
      if (!this.lastTime) {
        this.lastTime = timestamp;
      }

      const dt = timestamp - this.lastTime;
      this.lastTime = timestamp;

      if (this.isPaused) {
        if (timestamp - this.pauseStartTime > this.pauseTime) {
          this.isPaused = false;
          this.progress = 0;
        }
      } else {
        this.progress += dt / this.duration;
        if (this.progress >= 1) {
          this.progress = 1;
          this.isPaused = true;
          this.pauseStartTime = timestamp;
        }
      }

      this.draw();
      requestAnimationFrame(this.loop);
    };
  }

  document.querySelectorAll<HTMLCanvasElement>(".calibration-detour-canvas").forEach((canvas) => {
    if (canvas.dataset.initialized === "true") {
      return;
    }

    canvas.dataset.initialized = "true";
    new CalibrationDetourAnimation(canvas as HTMLCanvasElement);
  });
</script>
