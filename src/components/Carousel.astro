---
interface Props {
  id?: string;
  caption?: string;
}

const { id = `carousel-${Math.random().toString(36).slice(2, 8)}`, caption } = Astro.props;
---

<div class="carousel" id={id}>
  <div class="carousel-viewport">
    <div class="carousel-track">
      <slot />
    </div>
    <button class="carousel-btn prev" aria-label="Previous">&lsaquo;</button>
    <button class="carousel-btn next" aria-label="Next">&rsaquo;</button>
    <div class="carousel-dots"></div>
  </div>
  {caption && <div class="carousel-caption" set:html={caption} />}
</div>

<style>
  .carousel {
    margin: 1.5em 0;
  }

  .carousel-viewport {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
  }

  .carousel-track {
    display: flex;
    transition: transform 0.3s ease;
  }

  .carousel-track :global(.figure) {
    flex: 0 0 100%;
    min-width: 0;
    margin: 0;
  }

  .carousel-track :global(.figure figcaption) {
    display: none;
  }

  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(0, 0, 0, 0.4);
    color: white;
    border: none;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    font-size: 1.25rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    z-index: 1;
  }

  .carousel-btn:hover {
    background: rgba(0, 0, 0, 0.6);
  }

  .prev {
    left: 8px;
  }

  .next {
    right: 8px;
  }

  .carousel-dots {
    position: absolute;
    bottom: 24px;
    left: 0;
    right: 0;
    display: flex;
    justify-content: center;
    gap: 6px;
    z-index: 1;
  }

  .carousel-dots :global(.dot) {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.5);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 0.2s;
  }

  .carousel-dots :global(.dot.active) {
    background: rgba(255, 255, 255, 0.95);
  }

  @media (max-width: 640px) {
    .carousel-dots {
      bottom: 16px;
      gap: 4px;
    }

    .carousel-dots :global(.dot) {
      width: 6px;
      height: 6px;
    }
  }

  .carousel-caption {
    margin-top: 0.5em;
    font-size: 0.9em;
    color: rgb(var(--gray));
    text-align: center;
    min-height: 1.4em;
  }
</style>

<script>
  document.querySelectorAll('.carousel').forEach((carousel) => {
    const track = carousel.querySelector('.carousel-track') as HTMLElement;
    const items = track.querySelectorAll(':scope > *');
    const dotsContainer = carousel.querySelector('.carousel-dots')!;
    const prevBtn = carousel.querySelector('.prev')!;
    const nextBtn = carousel.querySelector('.next')!;
    let current = 0;

    const captionEl = carousel.querySelector('.carousel-caption') as HTMLElement | null;
    const hasFixedCaption = captionEl && captionEl.innerHTML.trim().length > 0;

    const captions = hasFixedCaption
      ? []
      : Array.from(items).map((item) => {
          const figcaption = item.querySelector('figcaption');
          return figcaption?.innerHTML?.trim() || '';
        });

    items.forEach((_, i) => {
      const dot = document.createElement('button');
      dot.className = `dot${i === 0 ? ' active' : ''}`;
      dot.addEventListener('click', () => goTo(i));
      dotsContainer.appendChild(dot);
    });

    function goTo(index: number) {
      current = Math.max(0, Math.min(index, items.length - 1));
      track.style.transform = `translateX(-${current * 100}%)`;
      dotsContainer.querySelectorAll('.dot').forEach((d, i) => {
        d.classList.toggle('active', i === current);
      });
      if (!hasFixedCaption && captionEl) {
        captionEl.innerHTML = captions[current];
      }
    }

    goTo(0);
    prevBtn.addEventListener('click', () => goTo(current - 1));
    nextBtn.addEventListener('click', () => goTo(current + 1));
  });
</script>
