---
const marchTokens = 796_804_187;
const aprilTokens = 5_766_978_229;
const increase = aprilTokens - marchTokens;
const ratio = aprilTokens / marchTokens;
const marchSizeRatio = Math.sqrt(marchTokens / aprilTokens);

const numberFormatter = new Intl.NumberFormat("ko-KR");
const compactFormatter = new Intl.NumberFormat("ko-KR", {
  maximumFractionDigits: 1,
});

const formatNumber = (value: number) => numberFormatter.format(value);
const formatHundredMillion = (value: number) =>
  `${compactFormatter.format(value / 100_000_000)}억`;
---

<figure
  class="token-usage"
  aria-label={`3월 ${formatNumber(marchTokens)} tokens, 4월 ${formatNumber(aprilTokens)} tokens, 약 ${ratio.toFixed(2)}배 증가`}
  style={`--march-size-ratio: ${marchSizeRatio};`}
>
  <figcaption>
    <span>월별 Codex 토큰 사용량</span>
  </figcaption>

  <div class="flow" aria-hidden="true">
    <div class="circle-wrap march">
      <div class="circle">
        <span class="month">3월</span>
        <strong>{formatHundredMillion(marchTokens)}</strong>
      </div>
      <span class="raw">{formatNumber(marchTokens)}</span>
    </div>

    <div class="arrow">
      <span>x{ratio.toFixed(2)}</span>
      <svg viewBox="0 0 168 86" aria-hidden="true">
        <defs>
          <linearGradient id="token-arrow-gradient" x1="10" x2="158" y1="42" y2="42" gradientUnits="userSpaceOnUse">
            <stop offset="0" stop-color="#2f6f73" stop-opacity="0.16"></stop>
            <stop offset="0.58" stop-color="#2f6f73" stop-opacity="0.72"></stop>
            <stop offset="1" stop-color="#2f6f73"></stop>
          </linearGradient>
          <filter id="token-arrow-shadow" x="-10%" y="-40%" width="120%" height="180%">
            <feDropShadow dx="0" dy="5" stdDeviation="3" flood-color="#2f6f73" flood-opacity="0.18"></feDropShadow>
          </filter>
        </defs>
        <path
          class="arrow-swoosh"
          d="M10 54C48 28 94 30 131 43L130 28L160 52L124 64L130 52C90 40 49 39 15 62Z"
        ></path>
      </svg>
    </div>

    <div class="circle-wrap april">
      <div class="circle">
        <span class="month">4월</span>
        <strong>{formatHundredMillion(aprilTokens)}</strong>
      </div>
      <span class="raw">{formatNumber(aprilTokens)}</span>
    </div>
  </div>
</figure>

<style>
  .token-usage {
    --april-size: clamp(12rem, 35vw, 16rem);
    --march-size: calc(var(--april-size) * var(--march-size-ratio));
    margin: 2.25em 0;
    padding: 1.4em;
    border: 1px solid rgba(var(--gray), 0.22);
    border-radius: 8px;
    background: #ffffff;
    color: rgb(var(--gray-dark));
  }

  .token-usage figcaption {
    margin-bottom: 0.95em;
    color: rgb(var(--black));
    font-size: 1.05em;
    font-weight: 700;
    text-align: left;
  }

  .flow {
    display: flex;
    gap: clamp(0.8rem, 4vw, 1.6rem);
    align-items: center;
    justify-content: center;
    margin-top: 1.3rem;
    margin-bottom: 1.2rem;
  }

  .circle-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 0;
  }

  .circle {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    color: #fff;
    text-align: center;
    box-shadow: 0 18px 32px rgba(var(--gray), 0.2);
  }

  .circle-wrap.march .circle {
    width: var(--march-size);
    height: var(--march-size);
    background: #9a8f72;
  }

  .circle-wrap.april .circle {
    width: var(--april-size);
    height: var(--april-size);
    background: #2f6f73;
  }

  .month {
    font-size: 0.82em;
    font-weight: 700;
    opacity: 0.84;
  }

  .circle strong {
    font-size: clamp(1.15rem, 4vw, 2.35rem);
    line-height: 1;
  }

  .circle-wrap.march .circle strong {
    font-size: clamp(0.95rem, 2.6vw, 1.35rem);
  }

  .raw {
    margin-top: 0.55rem;
    color: rgb(var(--gray));
    font-size: 0.78em;
    white-space: nowrap;
  }

  .arrow {
    position: relative;
    display: flex;
    min-width: clamp(5.5rem, 15vw, 8.5rem);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: #2f6f73;
    font-weight: 700;
    text-align: center;
  }

  .arrow span {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #2f6f73;
    font-size: clamp(1.4rem, 4vw, 2.25rem);
    line-height: 1;
    text-shadow: 0 8px 18px rgba(47, 111, 115, 0.16);
    white-space: nowrap;
  }

  .arrow svg {
    width: 100%;
    height: clamp(3rem, 9vw, 4.8rem);
    margin-top: -0.05rem;
    transform: scaleY(-1);
  }

  .arrow-swoosh {
    fill: url("#token-arrow-gradient");
    filter: url("#token-arrow-shadow");
  }

  @media (max-width: 520px) {
    .token-usage {
      padding: 1em;
    }

    .flow {
      gap: 0.7rem;
    }

    .arrow {
      min-width: 4rem;
    }

    .arrow span {
      font-size: 1.05rem;
    }

    .raw {
      display: none;
    }
  }
</style>
