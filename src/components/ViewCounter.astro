---
interface Props {
	viewKey: string;
	label: string;
}

const { viewKey, label } = Astro.props;
---

<span class="view-counter" data-view-counter data-view-key={viewKey} title={label}>
	<svg class="view-icon" viewBox="0 0 24 24" aria-hidden="true">
		<path d="M2.25 12s3.5-6.25 9.75-6.25S21.75 12 21.75 12 18.25 18.25 12 18.25 2.25 12 2.25 12Z"></path>
		<circle cx="12" cy="12" r="2.75"></circle>
	</svg>
	<span data-view-count>0</span>
	<span class="sr-only">{label}</span>
</span>

<style>
	.view-counter {
		display: inline-flex;
		gap: 0.25rem;
		align-items: center;
		justify-content: center;
		color: inherit;
		font-size: inherit;
	}

	.view-counter[data-state='error'] {
		display: none;
	}

	.view-icon {
		width: 1em;
		height: 1em;
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 1.8;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
</style>

<script>
	const VIEWED_STORAGE_PREFIX = 'post-viewed:';
	const VIEWED_TTL_MS = 12 * 60 * 60 * 1000;

	function formatCount(value) {
		const lang = document.documentElement.lang || undefined;
		return new Intl.NumberFormat(lang).format(value);
	}

	function hasRecentlyCounted(key) {
		try {
			const viewedAt = Number(localStorage.getItem(`${VIEWED_STORAGE_PREFIX}${key}`));
			return Number.isFinite(viewedAt) && Date.now() - viewedAt < VIEWED_TTL_MS;
		} catch {
			return false;
		}
	}

	function markRecentlyCounted(key) {
		try {
			localStorage.setItem(`${VIEWED_STORAGE_PREFIX}${key}`, String(Date.now()));
		} catch {
			// Counting should not depend on storage availability.
		}
	}

	async function requestViews(key, shouldIncrement) {
		const endpoint = '/api/views';

		if (shouldIncrement) {
			const response = await fetch(endpoint, {
				method: 'POST',
				headers: { 'content-type': 'application/json' },
				body: JSON.stringify({ key }),
			});

			if (!response.ok) {
				throw new Error('Failed to increment view count');
			}

			return response.json();
		}

		const response = await fetch(`${endpoint}?key=${encodeURIComponent(key)}`, {
			headers: { accept: 'application/json' },
		});

		if (!response.ok) {
			throw new Error('Failed to load view count');
		}

		return response.json();
	}

	async function updateViewCounter(counter) {
		const key = counter.dataset.viewKey;
		const count = counter.querySelector('[data-view-count]');

		if (!key || !count) {
			counter.dataset.state = 'error';
			return;
		}

		const shouldIncrement = !hasRecentlyCounted(key);

		try {
			const data = await requestViews(key, shouldIncrement);
			const views = Number(data.views ?? 0);

			if (shouldIncrement) {
				markRecentlyCounted(key);
			}

			count.textContent = formatCount(Number.isFinite(views) ? views : 0);
		} catch {
			counter.dataset.state = 'error';
		}
	}

	document.querySelectorAll('[data-view-counter]').forEach(updateViewCounter);
</script>
